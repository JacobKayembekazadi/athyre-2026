{% schema %}
{
  "name": "Product Page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show Share Buttons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Details"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ]
}
{% endschema %}

<div class="pt-32 pb-24 px-8 max-w-7xl mx-auto min-h-screen">
  <div class="grid md:grid-cols-2 gap-16">
    
    {/* LEFT: GALLERY */}
    <div class="space-y-4">
      {% for media in product.media %}
        <div class="aspect-[3/4] bg-stone-100 overflow-hidden rounded-[2px]">
          {{ media | image_url: width: 1000 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
        </div>
      {% endfor %}
    </div>

    {/* RIGHT: DETAILS */}
    <div class="sticky top-32 self-start">
      <div class="mb-8 border-b border-stone-100 pb-8">
        <span class="text-[10px] uppercase tracking-[0.4em] text-stone-400 font-bold block mb-2">{{ product.type }}</span>
        <h1 class="text-3xl font-serif italic text-stone-900 mb-4">{{ product.title }}</h1>
        <p class="text-xl font-light text-stone-600 mb-6">{{ product.price | money }}</p>
        <div class="prose prose-stone text-sm text-stone-500 leading-relaxed mb-6">
          {{ product.description }}
        </div>
      </div>

      {% form 'product', product %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        {/* VARIANTS */}
        {% unless product.has_only_default_variant %}
          <div class="mb-8">
            <label class="text-[9px] uppercase tracking-widest font-bold text-stone-400 block mb-4">Select Option</label>
            <div class="flex flex-wrap gap-4">
              {% for variant in product.variants %}
                <label class="cursor-pointer">
                  <input type="radio" name="id" value="{{ variant.id }}" class="peer sr-only" {% if forloop.first %}checked{% endif %}>
                  <div class="border border-stone-200 px-6 py-3 text-[10px] font-bold tracking-widest hover:border-stone-900 transition-colors peer-checked:bg-stone-900 peer-checked:text-white peer-checked:border-stone-900">
                    {{ variant.title }}
                  </div>
                </label>
              {% endfor %}
            </div>
          </div>
        {% endunless %}

        {/* ACTIONS */}
        <div class="flex gap-4">
          <button type="submit" class="flex-grow bg-stone-900 text-white py-4 text-[10px] tracking-[0.4em] font-black uppercase hover:bg-stone-800 transition-colors shadow-xl" {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}Add to Sanctuary{% else %}Sold Out{% endif %}
          </button>
          <button type="button" class="w-14 border border-stone-200 flex items-center justify-center hover:border-stone-900 transition-colors">
            {% render 'icon-heart', class: 'w-5 h-5 text-stone-400' %}
          </button>
        </div>
      {% endform %}

      {/* ACCORDION */}
      <div class="mt-12 space-y-4">
        {% for block in section.blocks %}
          <details class="group border-b border-stone-100 pb-4">
            <summary class="flex justify-between items-center cursor-pointer list-none py-2 text-[10px] uppercase tracking-[0.2em] font-bold text-stone-500 hover:text-stone-900 transition-colors">
              {{ block.settings.heading }}
              <span class="block w-4 h-4 relative">
                <span class="absolute top-1/2 left-0 w-full h-px bg-current transition-transform group-open:rotate-180"></span>
                <span class="absolute top-1/2 left-0 w-full h-px bg-current rotate-90 transition-transform group-open:rotate-180"></span>
              </span>
            </summary>
            <div class="text-sm text-stone-500 leading-relaxed pt-4 animate-in fade-in slide-in-from-top-2">
              {{ block.settings.content }}
            </div>
          </details>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
