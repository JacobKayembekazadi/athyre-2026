{% schema %}
{
  "name": "Product Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}

<div class="pt-32 pb-24 px-8 max-w-7xl mx-auto min-h-screen">
  
  {/* HEADER */}
  <header class="flex justify-between items-end mb-16 border-b border-stone-100 pb-8 sticky top-24 bg-white/95 backdrop-blur-sm z-30 transition-all duration-500">
    <div>
      <h1 class="text-[10px] uppercase tracking-[0.4em] text-stone-400 font-bold block mb-4">The Collection</h1>
      <span class="text-4xl md:text-5xl font-light tracking-tight uppercase">{{ collection.title }}</span>
    </div>
    
    <div class="flex gap-8">
      <div class="group relative cursor-pointer">
        <span class="text-[9px] uppercase tracking-widest font-bold flex items-center gap-2">
            Sort {% render 'icon-chevron-down', class: 'w-3 h-3' %}
        </span>
        {/* Simple mock sort dropdown, real theme would use URL params */}
      </div>
      <div class="group relative cursor-pointer">
        <span class="text-[9px] uppercase tracking-widest font-bold flex items-center gap-2">
            Filter {% render 'icon-filter', class: 'w-3 h-3' %}
        </span>
      </div>
    </div>
  </header>

  {/* GRID */}
  {% paginate collection.products by section.settings.products_per_page %}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {% for product in collection.products %}
        {% render 'product-card', product: product %}
      {% else %}
        <p>No products found.</p>
      {% endfor %}
    </div>

    {/* PAGINATION */}
    {% if paginate.pages > 1 %}
      <div class="flex justify-center mt-20 gap-4">
        {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="hover:text-stone-500">Previous</a>
        {% endif %}
        <span class="text-stone-400">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
        {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="hover:text-stone-500">Next</a>
        {% endif %}
      </div>
    {% endif %}
  {% endpaginate %}
</div>
