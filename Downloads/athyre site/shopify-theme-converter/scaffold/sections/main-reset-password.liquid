<section class="py-12 md:py-20">
  <div class="max-w-md mx-auto px-4 md:px-8">
    <h1 class="text-2xl md:text-3xl font-bold text-center mb-2">
      {{ 'customer.reset_password.title' | t | default: 'Reset Password' }}
    </h1>
    <p class="text-center text-stone-500 mb-8">
      {{ 'customer.reset_password.subtext' | t | default: 'Enter a new password for your account.' }}
    </p>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-6" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="space-y-4">
        <div>
          <label for="CustomerPassword" class="block text-sm font-medium text-stone-700 mb-1">
            {{ 'customer.reset_password.password' | t | default: 'New Password' }}
          </label>
          <input
            type="password"
            name="customer[password]"
            id="CustomerPassword"
            autocomplete="new-password"
            required
            class="w-full px-4 py-3 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-stone-900 focus:border-transparent"
          >
        </div>

        <div>
          <label for="CustomerPasswordConfirmation" class="block text-sm font-medium text-stone-700 mb-1">
            {{ 'customer.reset_password.password_confirm' | t | default: 'Confirm New Password' }}
          </label>
          <input
            type="password"
            name="customer[password_confirmation]"
            id="CustomerPasswordConfirmation"
            autocomplete="new-password"
            required
            class="w-full px-4 py-3 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-stone-900 focus:border-transparent"
          >
        </div>

        <button
          type="submit"
          class="w-full bg-stone-900 text-white py-3 px-6 rounded font-medium hover:bg-stone-800 transition-colors"
        >
          {{ 'customer.reset_password.submit' | t | default: 'Reset Password' }}
        </button>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Reset Password",
  "tag": "section"
}
{% endschema %}
