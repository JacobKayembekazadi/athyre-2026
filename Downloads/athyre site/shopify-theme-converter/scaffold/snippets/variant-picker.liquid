{%- comment -%}
  SCAFFOLD: Variant Picker with Option-Based Selection

  Supports both dropdown (select) and button/swatch styles.
  Includes color swatches for Color options.

  Required variables:
  - product: Product object
  - product_form_id: Form ID for the product form
  - block: Block object (optional, for settings)

  Usage:
  {% render 'variant-picker', product: product, product_form_id: product_form_id, block: block %}
{%- endcomment -%}

{%- unless product.has_only_default_variant -%}
  {%- liquid
    assign picker_type = block.settings.picker_type | default: 'button'
    assign section_id = section.id
  -%}

  {%- if picker_type == 'dropdown' -%}
    {%- comment -%} DROPDOWN STYLE {%- endcomment -%}
    <variant-selects
      class="variant-picker variant-picker--dropdown no-js-hidden"
      data-section="{{ section_id }}"
      data-url="{{ product.url }}"
      {{ block.shopify_attributes }}
    >
      {%- for option in product.options_with_values -%}
        <div class="variant-picker__option">
          <label class="variant-picker__label" for="Option-{{ section_id }}-{{ forloop.index0 }}">
            {{ option.name }}
          </label>
          <div class="variant-picker__select-wrapper">
            <select
              id="Option-{{ section_id }}-{{ forloop.index0 }}"
              class="variant-picker__select"
              name="options[{{ option.name | escape }}]"
              form="{{ product_form_id }}"
            >
              {%- for value in option.values -%}
                <option
                  value="{{ value | escape }}"
                  {% if option.selected_value == value %}selected="selected"{% endif %}
                >
                  {{ value }}
                </option>
              {%- endfor -%}
            </select>
            {% render 'icon-chevron-down' %}
          </div>
        </div>
      {%- endfor -%}

      <script type="application/json">
        {{ product.variants | json }}
      </script>
    </variant-selects>

  {%- else -%}
    {%- comment -%} BUTTON/SWATCH STYLE {%- endcomment -%}
    <variant-radios
      class="variant-picker variant-picker--buttons no-js-hidden"
      data-section="{{ section_id }}"
      data-url="{{ product.url }}"
      {{ block.shopify_attributes }}
    >
      {%- for option in product.options_with_values -%}
        {%- liquid
          assign option_name_handle = option.name | handleize
          assign is_color = false
          if option_name_handle == 'color' or option_name_handle == 'colour'
            assign is_color = true
          endif
        -%}

        <fieldset class="variant-picker__option{% if is_color %} variant-picker__option--color{% endif %}">
          <legend class="variant-picker__label">
            {{ option.name }}:
            <span class="variant-picker__value" data-option-value>{{ option.selected_value }}</span>
          </legend>

          <div class="variant-picker__inputs{% if is_color %} variant-picker__inputs--colors{% endif %}">
            {%- for value in option.values -%}
              {%- liquid
                assign variant_available = true
                assign option_disabled = true

                for variant in product.variants
                  case option.position
                    when 1
                      assign variant_option = variant.option1
                    when 2
                      assign variant_option = variant.option2
                    when 3
                      assign variant_option = variant.option3
                  endcase

                  if variant_option == value and variant.available
                    assign option_disabled = false
                    break
                  endif
                endfor
              -%}

              <input
                type="radio"
                id="Option-{{ section_id }}-{{ option.position }}-{{ value | handle }}"
                class="variant-picker__input visually-hidden"
                name="{{ option.name }}"
                value="{{ value | escape }}"
                form="{{ product_form_id }}"
                {% if option.selected_value == value %}checked{% endif %}
                {% if option_disabled %}disabled{% endif %}
              >
              <label
                class="variant-picker__button{% if is_color %} variant-picker__button--color{% endif %}{% if option_disabled %} variant-picker__button--unavailable{% endif %}"
                for="Option-{{ section_id }}-{{ option.position }}-{{ value | handle }}"
              >
                {%- if is_color -%}
                  {%- liquid
                    assign color_handle = value | handle
                    assign color_image = value | handle | append: '.png' | file_img_url: '50x50'
                  -%}
                  <span
                    class="variant-picker__swatch"
                    style="background-color: {{ color_handle }};{% if images[color_handle] %} background-image: url({{ color_handle | append: '.png' | file_img_url: '50x50' }});{% endif %}"
                  ></span>
                  <span class="visually-hidden">{{ value }}</span>
                {%- else -%}
                  <span class="variant-picker__button-text">{{ value }}</span>
                {%- endif -%}
              </label>
            {%- endfor -%}
          </div>
        </fieldset>
      {%- endfor -%}

      <script type="application/json">
        {{ product.variants | json }}
      </script>
    </variant-radios>
  {%- endif -%}

  {%- comment -%} No-JS Fallback {%- endcomment -%}
  <noscript>
    <div class="variant-picker variant-picker--noscript">
      <label class="variant-picker__label" for="Variants-{{ section_id }}">
        {{ 'products.product.select_variant' | t }}
      </label>
      <select
        id="Variants-{{ section_id }}"
        class="variant-picker__select"
        name="id"
        form="{{ product_form_id }}"
      >
        {%- for variant in product.variants -%}
          <option
            value="{{ variant.id }}"
            {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}
            {% unless variant.available %}disabled{% endunless %}
          >
            {{ variant.title }}
            {%- if variant.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}
            - {{ variant.price | money }}
          </option>
        {%- endfor -%}
      </select>
    </div>
  </noscript>
{%- endunless -%}

<style>
  .variant-picker {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .variant-picker__option {
    border: 0;
    padding: 0;
    margin: 0;
  }

  .variant-picker__label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .variant-picker__value {
    font-weight: 400;
  }

  .variant-picker__select-wrapper {
    position: relative;
  }

  .variant-picker__select-wrapper svg {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    width: 1rem;
    height: 1rem;
  }

  .variant-picker__select {
    width: 100%;
    padding: 0.75rem 2.5rem 0.75rem 1rem;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: var(--border-radius, 4px);
    background: var(--color-background, #fff);
    font-size: 1rem;
    appearance: none;
    cursor: pointer;
  }

  .variant-picker__inputs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .variant-picker__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: var(--border-radius, 4px);
    background: var(--color-background, #fff);
    cursor: pointer;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .variant-picker__input:checked + .variant-picker__button {
    border-color: var(--color-text, #000);
  }

  .variant-picker__button--unavailable {
    opacity: 0.5;
    text-decoration: line-through;
    cursor: not-allowed;
  }

  .variant-picker__button--color {
    width: 2.5rem;
    height: 2.5rem;
    min-width: unset;
    padding: 0.25rem;
    border-radius: 50%;
  }

  .variant-picker__swatch {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background-size: cover;
    background-position: center;
  }

  .variant-picker__input:checked + .variant-picker__button--color {
    box-shadow: 0 0 0 2px var(--color-background, #fff), 0 0 0 4px var(--color-text, #000);
  }
</style>
