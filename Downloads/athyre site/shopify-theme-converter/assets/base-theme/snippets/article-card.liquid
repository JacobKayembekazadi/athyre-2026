{%- comment -%}
  snippets/article-card.liquid

  Renders an article preview card for blog listings.

  Accepts:
  - article: {Article} Article object (required)
  - show_image: {Boolean} Show featured image (optional, default: true)
  - show_date: {Boolean} Show publish date (optional, default: true)
  - show_author: {Boolean} Show author name (optional, default: false)
  - show_excerpt: {Boolean} Show article excerpt (optional, default: true)
  - image_aspect_ratio: {String} 'adapt', 'square', 'portrait', 'landscape' (optional, default: 'landscape')
  - class: {String} Additional CSS classes (optional)

  Usage:
    {% render 'article-card', article: article %}
    {% render 'article-card', article: article, show_author: true, show_excerpt: false %}
{%- endcomment -%}

{%- liquid
  assign show_image = show_image | default: true
  assign show_date = show_date | default: true
  assign show_author = show_author | default: false
  assign show_excerpt = show_excerpt | default: true
  assign image_aspect_ratio = image_aspect_ratio | default: 'landscape'

  assign card_class = 'article-card'
  if class
    assign card_class = card_class | append: ' ' | append: class
  endif

  case image_aspect_ratio
    when 'square'
      assign aspect_ratio = '1 / 1'
    when 'portrait'
      assign aspect_ratio = '3 / 4'
    when 'landscape'
      assign aspect_ratio = '16 / 9'
    else
      assign aspect_ratio = 'auto'
  endcase
-%}

<article class="{{ card_class }}" itemscope itemtype="https://schema.org/BlogPosting">
  {%- if show_image -%}
    <a href="{{ article.url }}" class="article-card__image-link" style="--aspect-ratio: {{ aspect_ratio }};">
      {%- if article.image -%}
        {{
          article.image
          | image_url: width: 800
          | image_tag:
            class: 'article-card__image',
            loading: 'lazy',
            alt: article.image.alt | default: article.title,
            itemprop: 'image'
        }}
      {%- else -%}
        <div class="article-card__placeholder">
          {%- render 'icon', icon: 'mail', size: 48 -%}
        </div>
      {%- endif -%}
    </a>
  {%- endif -%}

  <div class="article-card__content">
    {%- if show_date or show_author -%}
      <div class="article-card__meta">
        {%- if show_date -%}
          <time class="article-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
            {{ article.published_at | date: format: 'abbreviated_date' }}
          </time>
        {%- endif -%}

        {%- if show_author and article.author -%}
          {%- if show_date -%}
            <span class="article-card__meta-separator" aria-hidden="true">&bull;</span>
          {%- endif -%}
          <span class="article-card__author" itemprop="author" itemscope itemtype="https://schema.org/Person">
            <span itemprop="name">{{ article.author }}</span>
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <h3 class="article-card__title" itemprop="headline">
      <a href="{{ article.url }}">{{ article.title }}</a>
    </h3>

    {%- if show_excerpt and article.excerpt_or_content != blank -%}
      <p class="article-card__excerpt" itemprop="description">
        {{ article.excerpt_or_content | strip_html | truncatewords: 25 }}
      </p>
    {%- endif -%}

    <a href="{{ article.url }}" class="article-card__link" aria-label="{{ 'blogs.article.read_more' | t | default: 'Read more' }}: {{ article.title }}">
      {{ 'blogs.article.read_more' | t | default: 'Read more' }}
      {%- render 'icon', icon: 'arrow-right', size: 16 -%}
    </a>
  </div>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-background, #fff);
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }

  .article-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .article-card__image-link {
    display: block;
    aspect-ratio: var(--aspect-ratio, 16 / 9);
    overflow: hidden;
  }

  .article-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .article-card:hover .article-card__image {
    transform: scale(1.05);
  }

  .article-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: var(--color-background-alt, #f5f5f5);
    color: var(--color-text-muted, #999);
  }

  .article-card__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted, #666);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-card__title {
    font-size: 1.125rem;
    line-height: 1.3;
    margin: 0 0 0.75rem;
  }

  .article-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .article-card__title a:hover {
    text-decoration: underline;
  }

  .article-card__excerpt {
    flex: 1;
    font-size: 0.875rem;
    color: var(--color-text-muted, #666);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .article-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary, #000);
    text-decoration: none;
    margin-top: auto;
  }

  .article-card__link:hover {
    text-decoration: underline;
  }

  .article-card__link .icon {
    transition: transform 0.2s ease;
  }

  .article-card__link:hover .icon {
    transform: translateX(4px);
  }
</style>
