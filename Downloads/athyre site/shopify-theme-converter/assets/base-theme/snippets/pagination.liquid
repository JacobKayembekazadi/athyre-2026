{%- comment -%}
  snippets/pagination.liquid

  Renders pagination controls for collections, blogs, and search results.

  Accepts:
  - paginate: {Paginate} The Shopify paginate object (required)
  - anchor: {String} ID to scroll to on page change (optional)
  - class: {String} Additional CSS classes (optional)

  Usage:
    {% paginate collection.products by 12 %}
      {% for product in collection.products %}
        ...
      {% endfor %}
      {% render 'pagination', paginate: paginate %}
    {% endpaginate %}
{%- endcomment -%}

{%- if paginate.pages > 1 -%}
  {%- liquid
    assign pagination_class = 'pagination'
    if class
      assign pagination_class = pagination_class | append: ' ' | append: class
    endif
  -%}

  <nav class="{{ pagination_class }}" aria-label="{{ 'general.pagination' | t | default: 'Pagination' }}">
    <ul class="pagination__list">
      {%- comment -%} Previous page link {%- endcomment -%}
      <li class="pagination__item pagination__item--prev">
        {%- if paginate.previous -%}
          <a
            href="{{ paginate.previous.url }}{% if anchor %}#{{ anchor }}{% endif %}"
            class="pagination__link pagination__link--prev"
            aria-label="{{ 'general.previous_page' | t | default: 'Previous page' }}"
          >
            {%- render 'icon', icon: 'chevron-left', size: 16 -%}
            <span class="pagination__link-text">{{ 'general.previous' | t | default: 'Previous' }}</span>
          </a>
        {%- else -%}
          <span class="pagination__link pagination__link--prev pagination__link--disabled" aria-disabled="true">
            {%- render 'icon', icon: 'chevron-left', size: 16 -%}
            <span class="pagination__link-text">{{ 'general.previous' | t | default: 'Previous' }}</span>
          </span>
        {%- endif -%}
      </li>

      {%- comment -%} Page numbers {%- endcomment -%}
      {%- for part in paginate.parts -%}
        <li class="pagination__item">
          {%- if part.is_link -%}
            <a
              href="{{ part.url }}{% if anchor %}#{{ anchor }}{% endif %}"
              class="pagination__link pagination__link--number"
              aria-label="{{ 'general.page' | t | default: 'Page' }} {{ part.title }}"
            >
              {{ part.title }}
            </a>
          {%- elsif part.title == paginate.current_page -%}
            <span
              class="pagination__link pagination__link--number pagination__link--current"
              aria-current="page"
              aria-label="{{ 'general.current_page' | t | default: 'Current page' }}, {{ 'general.page' | t | default: 'Page' }} {{ part.title }}"
            >
              {{ part.title }}
            </span>
          {%- else -%}
            <span class="pagination__link pagination__link--ellipsis" aria-hidden="true">
              {{ part.title }}
            </span>
          {%- endif -%}
        </li>
      {%- endfor -%}

      {%- comment -%} Next page link {%- endcomment -%}
      <li class="pagination__item pagination__item--next">
        {%- if paginate.next -%}
          <a
            href="{{ paginate.next.url }}{% if anchor %}#{{ anchor }}{% endif %}"
            class="pagination__link pagination__link--next"
            aria-label="{{ 'general.next_page' | t | default: 'Next page' }}"
          >
            <span class="pagination__link-text">{{ 'general.next' | t | default: 'Next' }}</span>
            {%- render 'icon', icon: 'chevron-right', size: 16 -%}
          </a>
        {%- else -%}
          <span class="pagination__link pagination__link--next pagination__link--disabled" aria-disabled="true">
            <span class="pagination__link-text">{{ 'general.next' | t | default: 'Next' }}</span>
            {%- render 'icon', icon: 'chevron-right', size: 16 -%}
          </span>
        {%- endif -%}
      </li>
    </ul>

    {%- comment -%} Page count info {%- endcomment -%}
    <div class="pagination__info">
      {{ 'general.page_of' | t: current: paginate.current_page, total: paginate.pages | default: 'Page [current] of [total]' | replace: '[current]', paginate.current_page | replace: '[total]', paginate.pages }}
    </div>
  </nav>

  <style>
    .pagination {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding: 2rem 0;
    }

    .pagination__list {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .pagination__link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      min-width: 2.5rem;
      height: 2.5rem;
      padding: 0 0.75rem;
      font-size: 0.875rem;
      text-decoration: none;
      color: var(--color-text, #000);
      background-color: transparent;
      border: 1px solid var(--color-border, #e5e5e5);
      border-radius: 4px;
      transition: all 0.2s ease;
    }

    .pagination__link:hover:not(.pagination__link--disabled):not(.pagination__link--current) {
      background-color: var(--color-background-alt, #f5f5f5);
      border-color: var(--color-text, #000);
    }

    .pagination__link--current {
      color: var(--color-background, #fff);
      background-color: var(--color-primary, #000);
      border-color: var(--color-primary, #000);
    }

    .pagination__link--disabled {
      color: var(--color-text-muted, #999);
      cursor: not-allowed;
      opacity: 0.5;
    }

    .pagination__link--ellipsis {
      border: none;
      min-width: auto;
      padding: 0 0.25rem;
    }

    .pagination__info {
      font-size: 0.875rem;
      color: var(--color-text-muted, #666);
    }

    /* Hide prev/next text on mobile, show only icons */
    @media (max-width: 640px) {
      .pagination__link-text {
        display: none;
      }

      .pagination__link--prev,
      .pagination__link--next {
        min-width: 2.5rem;
        padding: 0;
      }
    }
  </style>
{%- endif -%}
