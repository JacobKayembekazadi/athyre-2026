{%- comment -%}
  Password page - Shown when store is password protected
  Uses password_page_password form for storefront access
{%- endcomment -%}

<div class="password-page section-{{ section.id }}">
  <header class="password-header">
    {%- if section.settings.logo != blank -%}
      <a href="/" class="password-logo">
        {{ section.settings.logo | image_url: width: 300 | image_tag: loading: 'lazy' }}
      </a>
    {%- else -%}
      <a href="/" class="password-logo-text">{{ shop.name }}</a>
    {%- endif -%}
  </header>

  <main class="password-main">
    <div class="password-container">
      {%- if section.settings.heading != blank -%}
        <h1 class="password-title">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="password-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- form 'storefront_password' -%}
        <div class="password-form">
          {%- if form.errors -%}
            <div class="form-error" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="password-field-group">
            <label for="password" class="visually-hidden">
              {{ 'general.password_page.password_label' | t }}
            </label>
            <input
              type="password"
              name="password"
              id="password"
              class="password-input"
              placeholder="{{ 'general.password_page.password_placeholder' | t }}"
              autocomplete="current-password"
              required
            >
            <button type="submit" class="password-submit">
              {% render 'icon', icon: 'arrow-right' %}
              <span class="visually-hidden">{{ 'general.password_page.submit' | t }}</span>
            </button>
          </div>
        </div>
      {%- endform -%}

      {%- if section.settings.show_newsletter -%}
        <div class="password-newsletter">
          <p class="newsletter-heading">{{ section.settings.newsletter_heading }}</p>
          {%- form 'customer', class: 'newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter,password-page">

            {%- if form.posted_successfully? -%}
              <p class="newsletter-success">{{ 'general.newsletter.confirmation' | t }}</p>
            {%- else -%}
              <div class="newsletter-field-group">
                <label for="newsletter-email" class="visually-hidden">
                  {{ 'general.newsletter.email_label' | t }}
                </label>
                <input
                  type="email"
                  name="contact[email]"
                  id="newsletter-email"
                  class="newsletter-input"
                  placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
                  autocomplete="email"
                  required
                >
                <button type="submit" class="newsletter-submit">
                  {{ 'general.newsletter.submit' | t }}
                </button>
              </div>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_social -%}
        <div class="password-social">
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
              {% render 'icon', icon: 'facebook' %}
            </a>
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
              {% render 'icon', icon: 'instagram' %}
            </a>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
            <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" aria-label="Twitter">
              {% render 'icon', icon: 'twitter' %}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </main>

  <footer class="password-footer">
    <button type="button" class="admin-login-toggle" data-toggle-admin-login>
      {{ 'general.password_page.admin_link_html' | t }}
    </button>

    <div class="admin-login-modal" id="admin-login-modal" hidden>
      <div class="admin-login-backdrop" data-close-admin-login></div>
      <div class="admin-login-content">
        <button type="button" class="admin-login-close" data-close-admin-login aria-label="Close">
          {% render 'icon', icon: 'close' %}
        </button>
        <h2>{{ 'general.password_page.admin_title' | t }}</h2>
        <p>{{ 'general.password_page.admin_instructions' | t }}</p>
        <a href="/admin" class="btn btn--primary">
          {{ 'general.password_page.admin_button' | t }}
        </a>
      </div>
    </div>

    <p class="password-copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'general.password_page.powered_by_shopify_html' | t }}
    </p>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('admin-login-modal');

    document.querySelectorAll('[data-toggle-admin-login]').forEach(function(button) {
      button.addEventListener('click', function() {
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
      });
    });

    document.querySelectorAll('[data-close-admin-login]').forEach(function(element) {
      element.addEventListener('click', function() {
        modal.hidden = true;
        document.body.style.overflow = '';
      });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.hidden) {
        modal.hidden = true;
        document.body.style.overflow = '';
      }
    });
  });
</script>

<style>
  .password-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .password-header {
    padding: 2rem;
    text-align: center;
  }

  .password-logo img {
    max-height: 60px;
    width: auto;
  }

  .password-logo-text {
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
    color: inherit;
  }

  .password-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .password-container {
    max-width: 500px;
    width: 100%;
    text-align: center;
  }

  .password-title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .password-subtitle {
    font-size: 1.125rem;
    opacity: 0.8;
    margin-bottom: 2rem;
  }

  .password-form {
    margin-bottom: 2rem;
  }

  .form-error {
    background: #fef2f2;
    color: #dc2626;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .password-field-group {
    display: flex;
    max-width: 400px;
    margin: 0 auto;
  }

  .password-input {
    flex: 1;
    padding: 0.875rem 1rem;
    border: 2px solid {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
    border-right: none;
    border-radius: 4px 0 0 4px;
    font-size: 1rem;
    background: transparent;
    color: inherit;
  }

  .password-input::placeholder {
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.5 }};
  }

  .password-input:focus {
    outline: none;
    border-color: {{ section.settings.text_color }};
  }

  .password-submit {
    padding: 0.875rem 1.25rem;
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background_color }};
    border: 2px solid {{ section.settings.text_color }};
    border-radius: 0 4px 4px 0;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .password-submit:hover {
    opacity: 0.8;
  }

  .password-submit svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .password-newsletter {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
  }

  .newsletter-heading {
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .newsletter-field-group {
    display: flex;
    max-width: 400px;
    margin: 0 auto;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
    border-right: none;
    border-radius: 4px 0 0 4px;
    font-size: 0.875rem;
    background: transparent;
    color: inherit;
  }

  .newsletter-submit {
    padding: 0.75rem 1.25rem;
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background_color }};
    border: none;
    border-radius: 0 4px 4px 0;
    font-size: 0.875rem;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .newsletter-success {
    color: #16a34a;
    font-weight: 500;
  }

  .password-social {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .password-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid {{ section.settings.text_color | color_modify: 'alpha', 0.2 }};
    border-radius: 50%;
    color: inherit;
    transition: border-color 0.2s;
  }

  .password-social a:hover {
    border-color: {{ section.settings.text_color }};
  }

  .password-social svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .password-footer {
    padding: 2rem;
    text-align: center;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  .admin-login-toggle {
    background: none;
    border: none;
    color: inherit;
    text-decoration: underline;
    cursor: pointer;
    margin-bottom: 0.5rem;
  }

  .admin-login-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .admin-login-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .admin-login-content {
    position: relative;
    background: #fff;
    color: #000;
    padding: 2rem;
    border-radius: 8px;
    max-width: 400px;
    width: 90%;
    text-align: center;
  }

  .admin-login-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }

  .admin-login-content h2 {
    margin-bottom: 1rem;
  }

  .admin-login-content p {
    margin-bottom: 1.5rem;
    opacity: 0.7;
  }

  .btn--primary {
    display: inline-block;
    background: #000;
    color: #fff;
    padding: 0.875rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media (max-width: 640px) {
    .password-title {
      font-size: 1.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "class": "section-password",
  "settings": [
    {
      "type": "header",
      "content": "Branding"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening Soon"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're working hard to bring you something amazing. Enter the password to get early access."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Be the first to know when we launch"
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
