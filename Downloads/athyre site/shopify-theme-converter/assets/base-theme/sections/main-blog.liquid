{%- comment -%}
  sections/main-blog.liquid

  Blog listing page with article grid.
  Displays all articles from the current blog with pagination.
{%- endcomment -%}

<section class="section-{{ section.id }} blog-page">
  <div class="container">
    {%- render 'breadcrumb', blog: blog -%}

    <header class="blog-page__header">
      <h1 class="blog-page__title">{{ blog.title }}</h1>

      {%- if section.settings.show_description and blog.articles.size > 0 -%}
        {%- comment -%} Optional blog description - requires metafield or page content {%- endcomment -%}
      {%- endif -%}

      {%- if blog.tags.size > 0 and section.settings.show_tags -%}
        <nav class="blog-page__tags" aria-label="{{ 'blogs.tags' | t | default: 'Blog tags' }}">
          <ul class="blog-page__tags-list">
            <li>
              <a
                href="{{ blog.url }}"
                class="blog-page__tag{% unless current_tags %} blog-page__tag--active{% endunless %}"
              >
                {{ 'blogs.all' | t | default: 'All' }}
              </a>
            </li>
            {%- for tag in blog.all_tags -%}
              <li>
                <a
                  href="{{ blog.url }}/tagged/{{ tag | handle }}"
                  class="blog-page__tag{% if current_tags contains tag %} blog-page__tag--active{% endif %}"
                >
                  {{ tag }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}
    </header>

    {%- if blog.articles.size > 0 -%}
      {%- paginate blog.articles by section.settings.articles_per_page -%}
        <ul class="blog-page__grid" style="--grid-cols: {{ section.settings.columns_desktop }}; --grid-cols-mobile: {{ section.settings.columns_mobile }};">
          {%- for article in blog.articles -%}
            <li class="blog-page__item">
              {%- render 'article-card',
                article: article,
                show_image: section.settings.show_featured_image,
                show_date: section.settings.show_date,
                show_author: section.settings.show_author,
                show_excerpt: section.settings.show_excerpt
              -%}
            </li>
          {%- endfor -%}
        </ul>

        {%- render 'pagination', paginate: paginate -%}
      {%- endpaginate -%}

    {%- else -%}
      <div class="blog-page__empty">
        <p>{{ 'blogs.empty' | t | default: 'No articles yet. Check back soon!' }}</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  .section-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .blog-page__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .blog-page__title {
    margin-bottom: 1.5rem;
  }

  .blog-page__tags-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-page__tag {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--color-text, #000);
    background: var(--color-background-alt, #f5f5f5);
    border-radius: 2rem;
    transition: all 0.2s ease;
  }

  .blog-page__tag:hover {
    background: var(--color-primary, #000);
    color: var(--color-background, #fff);
  }

  .blog-page__tag--active {
    background: var(--color-primary, #000);
    color: var(--color-background, #fff);
  }

  .blog-page__grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-cols, 3), 1fr);
    gap: 2rem;
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  @media (max-width: 768px) {
    .blog-page__grid {
      grid-template-columns: repeat(var(--grid-cols-mobile, 1), 1fr);
    }
  }

  .blog-page__empty {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-text-muted, #666);
  }
{% endstyle %}

{% schema %}
{
  "name": "Blog posts",
  "tag": "section",
  "class": "section-blog",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 6,
      "max": 24,
      "step": 3,
      "default": 12
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "min": 1,
      "max": 2,
      "step": 1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Article card"
    },
    {
      "type": "checkbox",
      "id": "show_featured_image",
      "label": "Show featured image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "header",
      "content": "Filtering"
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show tag filters",
      "default": true
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "templates": ["blog"]
}
{% endschema %}
