{% schema %}
{
  "name": "Shipping Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shipping Rituals"
    }
  ],
  "presets": [
    {
      "name": "Shipping Page"
    }
  ]
}
{% endschema %}

<div class="pt-32 pb-24 px-8 max-w-7xl mx-auto min-h-screen">
  
  {/* SECTION 1: HERO */}
  <section class="text-center mb-32">
    <span class="text-[10px] uppercase tracking-[0.4em] text-stone-400 font-bold block mb-4">Logistics</span>
    <h1 class="text-4xl md:text-5xl font-light tracking-tight uppercase mb-8">{{ section.settings.heading }}</h1>
    <p class="text-stone-500 text-sm leading-loose max-w-2xl mx-auto">
      Each offering is prepared with intention and dispatched from our sanctuary.
    </p>
  </section>

  {/* SECTION 2: METHODS */}
  <section class="grid md:grid-cols-3 gap-8 mb-32">
    <div class="border border-stone-200 p-8 hover:border-stone-900 transition-colors">
        <h3 class="text-[10px] uppercase tracking-[0.3em] font-black mb-4">Standard</h3>
        <p class="text-[11px] text-stone-500 mb-4">3-5 Business Days</p>
        <span class="text-[10px] font-bold">Complimentary</span>
    </div>
    <div class="border border-stone-200 p-8 hover:border-stone-900 transition-colors">
        <h3 class="text-[10px] uppercase tracking-[0.3em] font-black mb-4">Expedited</h3>
        <p class="text-[11px] text-stone-500 mb-4">2 Business Days</p>
        <span class="text-[10px] font-bold">$25.00</span>
    </div>
    <div class="border border-stone-200 p-8 hover:border-stone-900 transition-colors">
        <h3 class="text-[10px] uppercase tracking-[0.3em] font-black mb-4">Global</h3>
        <p class="text-[11px] text-stone-500 mb-4">7-14 Business Days</p>
        <span class="text-[10px] font-bold">Calculated at Checkout</span>
    </div>
  </section>

  {/* SECTION 3: TIMELINE (Reusing vision timeline style or simplified) */}
  <section class="max-w-3xl mx-auto border-l border-stone-200 pl-12 space-y-12">
    <div class="relative">
        <span class="absolute -left-[54px] top-0 w-3 h-3 bg-stone-900 rounded-full ring-4 ring-white"></span>
        <span class="text-[9px] uppercase tracking-widest text-stone-400 block mb-2">Step 01</span>
        <h3 class="text-xl font-serif italic mb-2">Order Received</h3>
        <p class="text-sm text-stone-500">We confirm your offering via email immediately.</p>
    </div>
    <div class="relative">
        <span class="absolute -left-[54px] top-0 w-3 h-3 bg-stone-200 rounded-full ring-4 ring-white"></span>
        <span class="text-[9px] uppercase tracking-widest text-stone-400 block mb-2">Step 02</span>
        <h3 class="text-xl font-serif italic mb-2">Preparation</h3>
        <p class="text-sm text-stone-500">Your items are inspected and wrapped in our signature packaging.</p>
    </div>
    <div class="relative">
        <span class="absolute -left-[54px] top-0 w-3 h-3 bg-stone-200 rounded-full ring-4 ring-white"></span>
        <span class="text-[9px] uppercase tracking-widest text-stone-400 block mb-2">Step 03</span>
        <h3 class="text-xl font-serif italic mb-2">Departure</h3>
        <p class="text-sm text-stone-500">Carrier collects the package. Tracking number is sent to you.</p>
    </div>
  </section>
</div>
