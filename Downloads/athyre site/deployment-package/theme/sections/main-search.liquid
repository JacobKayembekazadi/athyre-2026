{% schema %}
{
  "name": "Search Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHAT ARE YOU SEEKING?"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured Collection (Grid 2)"
    }
  ]
}
{% endschema %}

<div class="pt-32 min-h-screen flex flex-col">
  
  {/* SECTION 1: SEARCH INPUT */}
  <section class="px-8 max-w-5xl mx-auto w-full mb-20">
    <form action="{{ routes.search_url }}" method="get" role="search" class="relative border-b-2 border-stone-200 focus-within:border-stone-900 transition-colors">
      <button type="submit" class="absolute left-0 top-1/2 -translate-y-1/2 w-6 h-6 text-stone-400">
        {% render 'icon-search' %}
      </button>
      <input 
        type="text" 
        name="q" 
        value="{{ search.terms | escape }}"
        placeholder="{{ section.settings.heading }}" 
        class="w-full bg-transparent py-6 pl-12 text-2xl md:text-4xl font-light uppercase tracking-widest placeholder:text-stone-300 focus:outline-none text-stone-900" 
      />
      <input type="hidden" name="type" value="product">
    </form>
  </section>

  {% if search.performed %}
    {/* SECTION 4: RESULTS GRID */}
    <section class="px-8 max-w-7xl mx-auto w-full flex-grow">
      <span class="text-[10px] uppercase tracking-[0.4em] text-stone-400 font-bold block mb-12">
        Search Results ({{ search.results_count }})
      </span>
      
      {% if search.results_count > 0 %}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              <a href="{{ item.url }}" class="group">
                <div class="aspect-[3/4] bg-stone-50 mb-4 overflow-hidden rounded-[2px]">
                  {% if item.featured_image %}
                    {{ item.featured_image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-105' }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-20' }}
                  {% endif %}
                </div>
                <h3 class="text-[10px] font-bold tracking-widest uppercase">{{ item.title }}</h3>
                <p class="text-stone-400 text-[10px]">{{ item.price | money }}</p>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <div class="text-center py-20 text-stone-400 text-sm uppercase tracking-widest">
          No sanctuary found for "{{ search.terms }}".
        </div>
      {% endif %}
    </section>
    
  {% else %}
    
    {/* SECTION 2: TRENDING */}
    <section class="px-8 max-w-7xl mx-auto w-full mb-32">
      <div class="flex items-center gap-2 mb-8 text-stone-400">
        {% render 'icon-trending-up' %}
        <span class="text-[10px] uppercase tracking-[0.4em] font-bold">Rising Now</span>
      </div>
      <div class="flex flex-wrap gap-4">
        {% assign terms = "Oversized Web, Ribbed Leggings, Yoga Mats, Gift Cards, Essential Crew" | split: ", " %}
        {% for term in terms %}
          <a href="{{ routes.search_url }}?q={{ term }}&type=product" class="px-8 py-3 border border-stone-200 text-[10px] uppercase tracking-[0.2em] font-bold hover:bg-stone-900 hover:text-white hover:border-stone-900 transition-all">
            {{ term }}
          </a>
        {% endfor %}
      </div>
    </section>

    {/* SECTION 3: CATEGORIES */}
    <section class="flex-grow bg-stone-50 py-24 border-t border-stone-100">
      <div class="px-8 max-w-7xl mx-auto w-full">
        <span class="text-[10px] uppercase tracking-[0.4em] text-stone-400 font-bold block mb-12">Browse by Category</span>
        <div class="grid md:grid-cols-3 gap-8">
           {% for collection in collections limit: 3 %}
             <a href="{{ collection.url }}" class="group relative aspect-video overflow-hidden">
                {% if collection.image %}
                  {{ collection.image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105' }}
                {% else %}
                   {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover grayscale group-hover:grayscale-0' }}
                {% endif %}
                <div class="absolute inset-0 bg-black/30 flex items-center justify-center">
                    <span class="text-white text-xl font-light tracking-[0.3em] uppercase group-hover:underline underline-offset-8 decoration-1">{{ collection.title }}</span>
                </div>
             </a>
           {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}
</div>
