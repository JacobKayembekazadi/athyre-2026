<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    {{ 'app.css' | asset_url | stylesheet_tag }}
    <script src="//unpkg.com/alpinejs" defer></script>

    {{ content_for_header }}

    {% style %}
      {% assign font_heading = settings.font_heading %}
      {% assign font_body = settings.font_body %}

      {{ font_heading | font_face: font_display: 'swap' }}
      {{ font_body | font_face: font_display: 'swap' }}

      :root {
        --font-heading-family: {{ font_heading.family }}, {{ font_heading.fallback_families }};
        --font-body-family: {{ font_body.family }}, {{ font_body.fallback_families }};

        --color-bg: {{ settings.color_bg }};
        --color-text: {{ settings.color_text }};
        --color-accent: {{ settings.color_accent }};
        --color-border: {{ settings.color_border }};
      }

      /* Base Overrides */
      body {
        font-family: var(--font-body-family);
        color: var(--color-text);
        background-color: var(--color-bg);
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading-family);
      }

      /* Tailwind Identity Hijacking (Making static classes dynamic) */
      .bg-white { background-color: var(--color-bg) !important; }
      .bg-stone-900 { background-color: var(--color-accent) !important; }
      .text-stone-900 { color: var(--color-text) !important; }
      .text-white { color: var(--color-bg) !important; } /* Inverted context */
      
      .font-sans { font-family: var(--font-body-family) !important; }
      .font-serif { font-family: var(--font-heading-family) !important; }

      .border-stone-100, .border-stone-200 { border-color: var(--color-border) !important; }
    {% endstyle %}

    <style>
      [x-cloak] { display: none !important; }
      .snap-x { scroll-snap-type: x mandatory; }
      .snap-start { scroll-snap-align: start; }
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
  </head>

  <body class="font-sans antialiased text-stone-900 bg-white selection:bg-stone-900 selection:text-white">
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}'
      };
    </script>
  </body>
</html>
